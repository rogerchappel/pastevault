{
  "name": "pastevault",
  "version": "0.1.0",
  "description": "Local-first TypeScript CLI for searchable clipboard and snippet history with secret redaction by default.",
  "type": "module",
  "bin": {
    "pastevault": "./dist/cli.js",
    "pv": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "README.md",
    "SECURITY.md",
    "ROADMAP.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json && node scripts/fix-bin-mode.mjs",
    "test": "node --test --import tsx tests/*.test.ts",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && bash scripts/validate.sh && npm pack --dry-run",
    "release:notes": "node /tmp/releasebox/bin/releasebox.js notes ."
  },
  "keywords": [
    "clipboard",
    "snippets",
    "local-first",
    "cli",
    "redaction",
    "developer-tools"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/pastevault.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/pastevault/issues"
  },
  "homepage": "https://github.com/rogerchappel/pastevault#readme",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
